{
  "name": "termp3",
  "version": "0.0.1",
  "description": "Retro terminal music player: stream YouTube/radios without downloading, with synced rooms and turn-based DJ rotation.",
  "type": "module",
  "bin": {
    "termp3": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build src/cli.ts --target node --outfile dist/cli.js",
    "build:binary": "bun build src/cli.ts --compile --outfile dist/termp3",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "terminal",
    "music",
    "player",
    "retro",
    "tui",
    "youtube",
    "cli",
    "mpv"
  ],
  "license": "MIT",
  "dependencies": {
    "ink": "^7.0.5",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.16",
    "typescript": "^6.0.3"
  }
}
