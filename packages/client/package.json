{
  "name": "catunes",
  "version": "0.1.1",
  "description": "Retro terminal music player with a real audio-reactive visualizer — stream YouTube & radios (no downloads), playlists, themes and multi-language. 🐱",
  "type": "module",
  "bin": {
    "catunes": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R0MADEV/catunes.git"
  },
  "homepage": "https://github.com/R0MADEV/catunes#readme",
  "bugs": {
    "url": "https://github.com/R0MADEV/catunes/issues"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "terminal",
    "music",
    "player",
    "retro",
    "tui",
    "youtube",
    "cli",
    "mpv"
  ],
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ink": "^7.0.5",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.16",
    "typescript": "^6.0.3"
  }
}
