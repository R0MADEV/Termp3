{
  "name": "termp3",
  "version": "0.0.1",
  "description": "Retro terminal music player: stream YouTube/radios without downloading, with synced rooms and turn-based DJ rotation.",
  "type": "module",
  "bin": {
    "termp3": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --target node --outfile dist/cli.js",
    "build:binary": "bun build src/cli.ts --compile --outfile dist/termp3"
  },
  "keywords": [
    "terminal",
    "music",
    "player",
    "retro",
    "tui",
    "youtube",
    "cli",
    "mpv"
  ],
  "license": "MIT",
  "dependencies": {
    "blessed": "^0.1.81"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/bun": "^1.3.14"
  }
}
